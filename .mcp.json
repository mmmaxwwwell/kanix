{
  "mcpServers": {
    "mcp-android": {
      "command": "mcp-android",
      "args": [
        "--emulator"
      ],
      "env": {
        "ANDROID_USER_HOME": ".dev/android-user-home",
        "ANDROID_AVD_HOME": ".dev/android-user-home/avd",
        "ANDROID_BUILD_ROOT": "customer"
      }
    },
    "mcp-browser": {
      "command": "mcp-browser",
      "args": [
        "--headless"
      ]
    },
    "code-review-graph": {
      "command": "code-review-graph",
      "args": [
        "serve"
      ],
      "type": "stdio"
    }
  }
}
