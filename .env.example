# =============================================================================
# Kanix Commerce Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# PostgreSQL connection string used by the API server and Liquibase migrations.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://kanix:kanix@localhost:5432/kanix

# ---------------------------------------------------------------------------
# Stripe (Payments)
# ---------------------------------------------------------------------------
# Secret key from the Stripe dashboard (starts with sk_test_ or sk_live_).
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Webhook signing secret for verifying Stripe webhook payloads (starts with whsec_).
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Enable Stripe Tax for automatic tax calculation (true | false).
STRIPE_TAX_ENABLED=false

# ---------------------------------------------------------------------------
# SuperTokens (Authentication)
# ---------------------------------------------------------------------------
# API key for communicating with the SuperTokens core.
SUPERTOKENS_API_KEY=REPLACE_ME

# Connection URI for the SuperTokens core instance.
SUPERTOKENS_CONNECTION_URI=http://localhost:3567

# ---------------------------------------------------------------------------
# EasyPost (Shipping)
# ---------------------------------------------------------------------------
# API key from the EasyPost dashboard (starts with EZ...).
EASYPOST_API_KEY=EZAK_REPLACE_ME

# ---------------------------------------------------------------------------
# GitHub OAuth (Contributor Login)
# ---------------------------------------------------------------------------
# OAuth App credentials from GitHub Developer Settings.
GITHUB_OAUTH_CLIENT_ID=REPLACE_ME
GITHUB_OAUTH_CLIENT_SECRET=REPLACE_ME

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# Logging level: DEBUG | INFO | WARN | ERROR | FATAL
LOG_LEVEL=INFO

# Port the API server listens on.
PORT=3000
