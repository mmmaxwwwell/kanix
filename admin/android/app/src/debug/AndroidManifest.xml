<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Allow cleartext HTTP/WebSocket to the emulator host (10.0.2.2) so
         the app can reach the local API server at http://10.0.2.2:3000.
         Android 9+ (targetSdk 28+) blocks cleartext by default; without this
         the auth check and WebSocket connect both hang until Dio's 10-second
         connectTimeout fires, making the app appear frozen on startup. -->
    <application android:usesCleartextTraffic="true" />
</manifest>
