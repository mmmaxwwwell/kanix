---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Base
  title="Returns Policy - Kanix™"
  description="Kanix™ returns and refund policy. 30-day return window for unused products purchased from our official store."
>
  <Header activePath="returns" />

  <main id="main" class="pt-20 pb-16 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <a href={import.meta.env.BASE_URL} class="text-sm text-neutral-500 hover:text-white transition-colors mb-6 inline-block">
        &larr; Back to home
      </a>

      <h1 class="text-3xl sm:text-5xl font-bold tracking-tight mb-8">Returns Policy</h1>

      <div class="space-y-12">
        <!-- 30-Day Return Window -->
        <section>
          <h2 class="text-xl font-semibold text-white mb-4">30-Day Return Window</h2>
          <div class="text-neutral-400 leading-relaxed space-y-4">
            <p>
              Products purchased from the official Kanix™ store may be returned within <strong class="text-white">30 days of delivery</strong> for a full refund, provided they meet the conditions below.
            </p>
          </div>
        </section>

        <!-- Conditions -->
        <section>
          <h2 class="text-xl font-semibold text-white mb-4">Return Conditions</h2>
          <div class="space-y-4">
            <div class="bg-neutral-900 border border-neutral-800 rounded-lg p-5">
              <h3 class="text-sm font-semibold text-green-500 mb-2">Eligible for Return</h3>
              <ul class="text-neutral-400 text-sm space-y-2 list-disc pl-5">
                <li>Unused, unmodified products in original condition</li>
                <li>Products with manufacturing defects (any condition)</li>
                <li>Incorrect items shipped (wrong product or variant)</li>
                <li>Products damaged during shipping</li>
              </ul>
            </div>
            <div class="bg-neutral-900 border border-neutral-800 rounded-lg p-5">
              <h3 class="text-sm font-semibold text-red-400 mb-2">Not Eligible for Return</h3>
              <ul class="text-neutral-400 text-sm space-y-2 list-disc pl-5">
                <li>Products that have been used, mounted, or show signs of wear</li>
                <li>Products damaged by heat exposure, misuse, or modification</li>
                <li>Products returned after the 30-day window</li>
                <li>Self-printed parts from downloaded files (digital files are non-returnable)</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Refund Process -->
        <section>
          <h2 class="text-xl font-semibold text-white mb-4">Refund Process</h2>
          <div class="text-neutral-400 leading-relaxed space-y-4">
            <p>
              To initiate a return, contact us through the customer portal with your order number and reason for the return. We will provide a return shipping label for eligible returns.
            </p>
            <p>
              Refunds are processed within <strong class="text-white">5-10 business days</strong> after we receive and inspect the returned item. The refund will be issued to the original payment method.
            </p>
            <p>
              For defective products or shipping errors, we cover return shipping costs. For all other eligible returns, the customer is responsible for return shipping.
            </p>
          </div>
        </section>

        <!-- Exchanges -->
        <section>
          <h2 class="text-xl font-semibold text-white mb-4">Exchanges</h2>
          <div class="text-neutral-400 leading-relaxed space-y-4">
            <p>
              We do not offer direct exchanges. To receive a different product or variant, return the original item for a refund and place a new order.
            </p>
          </div>
        </section>

        <!-- Safety Disclaimer -->
        <section>
          <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6">
            <h2 class="text-sm font-semibold text-neutral-400 uppercase tracking-wider mb-3">Safety Disclaimer</h2>
            <p class="text-neutral-500 text-xs leading-relaxed">
              3D-printed parts can vary in strength and durability depending on material, print settings, and environmental conditions. These products are designed as accessories for dog handling belts and are not safety-critical equipment. Inspect your modules regularly and replace any parts showing signs of wear, cracking, or deformation. Kanix™ is not responsible for injury, damage, or loss resulting from the use of these products. Always supervise dogs when using any handling equipment. Use at your own risk.
            </p>
          </div>
        </section>
      </div>
    </div>
  </main>

  <Footer />
</Base>
