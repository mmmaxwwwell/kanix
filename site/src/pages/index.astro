---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { modules, comingSoonModules } from "../data/modules";
import { loadouts, resolveLoadout } from "../data/loadouts";
import BeltLayoutPanel from "../components/BeltLayoutPanel.astro";

const repoUrl = "https://github.com/mmmaxwwwell/kanix";

// Mounting systems (the things you pick first, before any accessory). Anything
// not in this set is a regular accessory module.
const MOUNTING_SLUGS = new Set(["kanix-plate", "belt-clip"]);
const mountingSystems = modules.filter((m) => MOUNTING_SLUGS.has(m.slug));
const accessoryModules = modules.filter((m) => !MOUNTING_SLUGS.has(m.slug));

// Loadout used for the "preview" belt layout under the loadout cards. The
// Pro loadout has the most modules placed around the belt, so it makes the
// richest top-down preview.
const previewLoadout = loadouts.find((l) => l.slug === "pro");
---

<Base
  title="Kanix™ - Open-Source Modular Dog Handler Belt System"
  description="Kanix™ is a free, open-source modular belt system for dog handlers. Built for trainers, walkers, and everyday dog owners."
>
  <Header showModulesAnchor />

  <main id="main">
  <!-- Hero -->
  <section id="hero" class="relative min-h-screen flex items-center justify-center px-6 pt-20 transition-[min-height] duration-100 ease-out">
    <div class="max-w-3xl text-center">
      <img
        src={`${import.meta.env.BASE_URL}logo1.svg`}
        alt="Kanix logo"
        class="w-32 sm:w-40 h-32 sm:h-40 mx-auto mb-6 logo-amber"
      />
      <h1 class="text-5xl sm:text-7xl font-black tracking-tight leading-[1.05] mb-6">
        Your Belt.<br />Your Build.<br />Your Way.
      </h1>
      <p class="text-sm font-semibold tracking-widest uppercase text-amber-500 mb-6">
        Free & Open Source
      </p>
      <p class="text-lg sm:text-xl text-neutral-400 max-w-xl mx-auto mb-10 leading-relaxed">
        Kanix™ is a modular belt system for dog handlers. Mix and match modules to build
        the perfect setup for training, walking, or working with dogs.
      </p>
      <a
        href="#loadouts"
        class="inline-flex items-center gap-2 px-8 py-3 bg-white text-neutral-950 font-semibold rounded-lg hover:bg-neutral-200 transition-colors"
      >
        View Belts
      </a>
    </div>
  </section>

  <script>
    const hero = document.getElementById("hero")!;
    const content = hero.firstElementChild as HTMLElement;

    function onScroll() {
      const scrollY = window.scrollY;
      const contentHeight = content.offsetHeight + 80; // content + padding
      const viewportHeight = window.innerHeight;
      const extraSpace = viewportHeight - contentHeight;

      if (extraSpace <= 0) return; // content already fills viewport

      const collapse = Math.min(scrollY * 3, extraSpace);
      hero.style.minHeight = `${viewportHeight - collapse}px`;
    }

    window.addEventListener("scroll", onScroll, { passive: true });
  </script>

  <!-- Who it's for -->
  <section class="py-24 px-6">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-12">
        Built for Every Dog Handler
      </h2>
      <div class="grid sm:grid-cols-3 gap-8">
        {[
          {
            title: "Professional Trainers",
            text: "Keep spray, treats, leads, and tools organized and instantly accessible during sessions with reactive or high-energy dogs.",
          },
          {
            title: "Dog Walkers",
            text: "Manage multiple dogs with hands-free gear. Waste bags, flashlights, and leash anchors all in easy reach while keeping both hands on the leads.",
          },
          {
            title: "Everyday Owners",
            text: "Simplify your daily walks. Stop juggling bags, treats, and flashlights in your pockets. Build a belt setup that fits your routine.",
          },
        ].map(({ title, text }) => (
          <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-8 text-left">
            <h3 class="text-lg font-semibold mb-3 text-white">{title}</h3>
            <p class="text-neutral-400 leading-relaxed">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section id="how-it-works" class="py-24 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-12">
        How It Works
      </h2>
      <div class="grid sm:grid-cols-3 gap-8">
        {[
          {
            step: "1",
            title: "Choose Your Belt",
            text: "Pick a 1.5\" or 2\" duty belt, or use the Kanix™ belt-clip adapter to mount onto any regular pants belt.",
          },
          {
            step: "2",
            title: "Choose Your Modules",
            text: "Browse the available modules and pick the ones that match your gear and workflow.",
          },
          {
            step: "3",
            title: "Mount & Go",
            text: "Bolt your modules onto Kanix™ belt clips, slide them onto your belt, and rearrange anytime.",
          },
        ].map(({ step, title, text }) => (
          <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 flex flex-col items-center text-center">
            <div class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-amber-500/10 text-amber-500 font-bold text-lg mb-4">
              {step}
            </div>
            <h3 class="text-lg font-semibold mb-2 text-white">{title}</h3>
            <p class="text-neutral-400 leading-relaxed">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Suggested Kanix Belts -->
  <section id="loadouts" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4 text-center">
        Suggested Kanix™ Belts
      </h2>
      <p class="text-neutral-400 text-center mb-4 max-w-2xl mx-auto">
        Not sure where to start? Pick a Kanix™ Belt built for how you actually work with dogs. Each one is a starting point — swap modules in or out to match your setup.
      </p>
      <p class="text-neutral-500 text-center mb-12 max-w-2xl mx-auto text-sm">
        Or skip the suggestions and <a href="#modules" class="text-amber-500 hover:text-amber-400 transition-colors">build your own from scratch</a> — every module is browsable below.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-2 gap-6">
        {loadouts.map((loadout) => {
          const { slug, name, tagline, belt } = loadout;
          const resolved = resolveLoadout(loadout);
          // Collapse repeats (e.g. two carabiner-clip entries) into a single
          // bullet with a "× N" badge. A variant array counts as that many
          // instances; a single variant or no variant counts as one.
          // Look up a variant id's display label (e.g. "tiny" → "Tiny") so
          // collapsed bullets like "Carabiner Clip (Tiny) ×2" stay readable.
          // Skips "Belt size" groups — those are already implied by the
          // loadout's belt chip and would just be noise on the card.
          const variantLabel = (mod, variantId) => {
            const gv = "genericVariants" in mod ? mod.genericVariants : undefined;
            if (!gv) return null;
            for (const g of gv.groups) {
              if (g.label === "Belt size") continue;
              const opt = g.options.find((o) => o.id === variantId);
              if (opt) return opt.label;
            }
            return null;
          };
          // Collapse on (slug, variant) so a tiny carabiner and two small
          // carabiners stay distinguishable on the card.
          const counts = new Map();
          const isCarabiner = (entry) =>
            entry.kind !== "group" && entry.module.slug === "carabiner-clip";
          for (const entry of resolved) {
            if (entry.kind === "group") {
              const key = `group:${entry.groupLabel}`;
              const existing = counts.get(key);
              if (existing) existing.count += 1;
              else counts.set(key, { label: entry.groupLabel, count: 1, isCarabiner: false });
              continue;
            }
            const variants = Array.isArray(entry.variant)
              ? entry.variant
              : entry.variant
                ? [entry.variant]
                : [null];
            for (const v of variants) {
              const display = v ? variantLabel(entry.module, v) : null;
              const key = `mod:${entry.module.slug}:${display ?? ""}`;
              const label = display
                ? `${entry.module.name} (${display})`
                : entry.module.name;
              const existing = counts.get(key);
              if (existing) existing.count += 1;
              else counts.set(key, { label, count: 1, isCarabiner: isCarabiner(entry) });
            }
          }
          // Always sort carabiner-clip rows to the end of the card list —
          // preserves their relative order, just bumps them after everything
          // else so the "primary" gear shows first.
          const moduleEntries = Array.from(counts.values()).sort((a, b) => {
            if (a.isCarabiner === b.isCarabiner) return 0;
            return a.isCarabiner ? 1 : -1;
          });
          return (
            <a
              href={`${import.meta.env.BASE_URL}loadouts/${slug}/`}
              class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 flex flex-col hover:border-neutral-600 transition-colors group"
            >
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="text-xl font-bold text-white group-hover:text-amber-500 transition-colors">{name}</h3>
                <div class="flex flex-wrap gap-1.5 justify-end">
                  <span class="px-2 py-0.5 text-[0.65rem] font-semibold uppercase tracking-wider bg-amber-500/10 text-amber-500 rounded-full border border-amber-500/20 whitespace-nowrap">
                    {`${belt} belt`}
                  </span>
                  <span class="px-2 py-0.5 text-[0.65rem] font-semibold uppercase tracking-wider bg-amber-500/10 text-amber-500 rounded-full border border-amber-500/20 whitespace-nowrap">
                    {`${moduleEntries.length} Kanix™ ${moduleEntries.length === 1 ? "module" : "modules"}`}
                  </span>
                </div>
              </div>
              <p class="text-neutral-400 leading-relaxed mb-4">{tagline}</p>
              <ul class="text-sm text-neutral-300 mb-4 flex-1 space-y-1 list-disc list-inside marker:text-amber-500/60">
                {moduleEntries.map(({ label, count }) => (
                  <li>
                    {label}
                    {count > 1 && (
                      <span class="ml-1.5 text-xs text-neutral-500">×{count}</span>
                    )}
                  </li>
                ))}
              </ul>
              <span class="text-sm text-amber-500 group-hover:text-amber-400 transition-colors font-medium">
                View belt &rarr;
              </span>
            </a>
          );
        })}
      </div>

      {previewLoadout && (
        <div class="mt-12">
          <a
            href={`${import.meta.env.BASE_URL}loadouts/${previewLoadout.slug}/`}
            class="group block w-full rounded-xl border border-amber-500/40 bg-neutral-900 px-6 py-4 mb-3 text-center shadow-md hover:border-amber-400 transition-colors"
          >
            <span class="block text-2xl sm:text-3xl font-bold tracking-tight text-amber-500 group-hover:text-amber-400 transition-colors">
              {previewLoadout.name}
            </span>
            <span class="block mt-1 text-xs uppercase tracking-widest text-neutral-400">
              top-down belt layout
            </span>
          </a>
          <BeltLayoutPanel loadout={previewLoadout} compact />
        </div>
      )}
    </div>
  </section>

  <!-- Mounting Systems -->
  <section id="mounting-systems" class="py-24 px-6 bg-neutral-900/50">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4 text-center">
        Mounting Systems
      </h2>
      <p class="text-neutral-400 text-center mb-12 max-w-xl mx-auto">
        Pick one of these first — every module below bolts onto it.
      </p>
      <div class="grid sm:grid-cols-2 gap-6">
        {mountingSystems.map(({ slug, name, description }) => (
          <a
            href={`${import.meta.env.BASE_URL}modules/${slug}/`}
            class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 flex flex-col hover:border-neutral-600 transition-colors group"
          >
            <h3 class="text-lg font-semibold mb-2 text-white group-hover:text-amber-500 transition-colors">{name}</h3>
            <p class="text-neutral-400 leading-relaxed mb-4 flex-1">{description}</p>
            <span class="text-sm text-amber-500 group-hover:text-amber-400 transition-colors font-medium">
              View 3D Model &rarr;
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Modules -->
  <section id="modules" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4 text-center">
        Available Modules
      </h2>
      <p class="text-neutral-400 text-center mb-12 max-w-xl mx-auto">
        Every module bolts onto the universal Kanix™ grid. Mix, match, and rearrange to suit your needs.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {accessoryModules.map(({ slug, name, description }) => (
          <a
            href={`${import.meta.env.BASE_URL}modules/${slug}/`}
            class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 flex flex-col hover:border-neutral-600 transition-colors group"
          >
            <h3 class="text-lg font-semibold mb-2 text-white group-hover:text-amber-500 transition-colors">{name}</h3>
            <p class="text-neutral-400 leading-relaxed mb-4 flex-1">{description}</p>
            <span class="text-sm text-amber-500 group-hover:text-amber-400 transition-colors font-medium">
              View 3D Model &rarr;
            </span>
          </a>
        ))}
        {comingSoonModules.map(({ slug, name, description }) => (
          <a
            href={`${import.meta.env.BASE_URL}coming-soon/${slug}/`}
            class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 flex flex-col hover:border-neutral-600 transition-colors group relative"
          >
            <span class="absolute top-4 right-4 px-2 py-0.5 text-[0.65rem] font-semibold uppercase tracking-wider bg-amber-500/10 text-amber-500 rounded-full border border-amber-500/20">
              Coming Soon
            </span>
            <h3 class="text-lg font-semibold mb-2 text-white group-hover:text-amber-500 transition-colors pr-24">{name}</h3>
            <p class="text-neutral-400 leading-relaxed mb-4 flex-1">{description}</p>
            <span class="text-sm text-amber-500 group-hover:text-amber-400 transition-colors font-medium">
              View Details &rarr;
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- What is Kanix -->
  <section class="py-24 px-6 bg-neutral-900/50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-8 text-center">
        What is Kanix™?
      </h2>
      <div class="text-neutral-400 leading-relaxed max-w-3xl mx-auto">
        <p class="mb-4">
          Kanix™ is a modular mounting system that turns any belt into a fully customized dog
          handling rig. Each module snaps onto a standard Kanix™ belt clip using a universal
          bolt pattern, so you can rearrange your gear in seconds.
        </p>
        <p class="mb-4">
          You can wear it two ways:
        </p>
        <ul class="mb-4 space-y-2 list-disc pl-6">
          <li>
            <strong class="text-white">Mount to a duty belt.</strong> Bolt your modules onto a
            full-width Kanix™ plate that slides directly onto a 1.5" or 2" duty belt — the
            stiffest, most secure option, and what we recommend if you're carrying multiple modules.
          </li>
          <li>
            <strong class="text-white">Clip to a regular belt.</strong> Don't want a separate duty
            belt? Use the Kanix™ belt-clip adapter — it clamps onto any standard pants belt and
            exposes the same bolt grid, so every Kanix™ module still works.
          </li>
        </ul>
        <p class="mb-4">
          Whether you're a professional trainer managing reactive dogs, a dog walker juggling
          multiple leashes, or an owner who just wants hands-free access to bags and treats,
          Kanix™ gives you a system that adapts to your workflow.
        </p>
        <p>
          Every module is designed in OpenSCAD, fully parametric, and released under an open-source
          license. Download the files and print them yourself, modify the designs to fit your exact
          gear, or contribute your own modules back to the community.
        </p>
      </div>
    </div>
  </section>

  <!-- Why Kanix -->
  <section class="py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-8 text-center">
        Why Kanix™?
      </h2>
      <div class="text-neutral-400 leading-relaxed max-w-3xl mx-auto">
        <p class="mb-4">
          Kanix™ started because of a problem every dog owner knows: you're on a walk with pockets
          stuffed full of bags, treats, a flashlight, your phone, and keys, and none of it is where
          you need it when you need it. The treat pouch belt is sliding down your waist again.
          The clip-on bag holder fell off somewhere two blocks back. And your dog just
          pooped in the neighbor's yard, but the bags are sitting on the kitchen counter.
        </p>
        <p class="mb-4">
          And if an off-leash dog ever charges yours, you need your spray immediately, not
          buried in a pocket. You don't get to fumble when seconds count. Your gear needs to be
          in a fixed position, right where your hand expects it, every single time.
        </p>
        <p>
          That's why Kanix™ exists — purpose-built mounts that keep every piece of gear locked in
          place and instantly accessible. Bolt them onto a duty belt for the most secure setup, or
          clip them onto a regular pants belt with the Kanix™ belt-clip adapter — either way,
          everything sits in a fixed position, right where your hand expects it. No more
          juggling. No more hoping you can find what you need in time.
        </p>
      </div>
    </div>
  </section>

  <!-- The Belt -->
  <section id="the-belt" class="py-24 px-6 bg-neutral-900/50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-8 text-center">
        What's a Duty Belt?
      </h2>
      <div class="text-neutral-400 leading-relaxed max-w-3xl mx-auto">
        <p class="mb-4">
          A duty belt is a rigid, heavy-duty belt originally designed for law enforcement and military
          use. Unlike a regular belt, it's built to carry weight without sagging, distributing
          the load of holsters, pouches, and tools evenly around your waist.
        </p>
        <p class="mb-4">
          Kanix™ supports both <strong class="text-white">1.5"</strong> and <strong class="text-white">2"</strong> duty belts.
          We recommend the <a href="https://www.amazon.com/dp/B0G2PTBGF2" target="_blank" rel="noopener noreferrer" class="text-amber-500 hover:text-amber-400 transition-colors">2" with MOLLE webbing</a> — it's the stiffest option and gives you an extra row of
          webbing for any non-Kanix gear you already own. All three belts below use the same Kanix™ bolt pattern;
          pick the size you want to wear and print the matching plate or belt-clip variant. Every module attaches with
          <a href="https://www.amazon.com/dp/B08DS7XJN8" target="_blank" rel="noopener noreferrer" class="text-amber-500 hover:text-amber-400 transition-colors">M5×10 button-head cap screws</a>.
        </p>
        <p class="mb-8">
          Wearing a belt size that's not 1.5" or 2"?
          <a href={`${import.meta.env.BASE_URL}#custom-requests`} class="text-amber-500 hover:text-amber-400 transition-colors">Open an issue</a>
          with the belt width and a link to the product — we'll add it.
        </p>
      </div>
      <div class="grid sm:grid-cols-3 gap-4 max-w-4xl mx-auto">
        <a
          href="https://www.amazon.com/dp/B0G2PTBGF2"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 flex flex-col hover:border-neutral-600 transition-colors group"
        >
          <p class="text-sm text-amber-500 uppercase tracking-wider font-semibold mb-3">Recommended — 2" with MOLLE</p>
          <p class="text-white font-medium mb-1 group-hover:text-amber-500 transition-colors">IDOGEAR SPORTS Tactical 2" Heavy-Duty MOLLE Belt</p>
          <p class="text-neutral-500 text-sm mb-4 flex-1">
            A 2" duty belt with full MOLLE/PALS webbing. Kanix™ bolt grid plus extra rows of webbing for any non-Kanix gear.
          </p>
          <span class="inline-flex items-center gap-2 text-amber-500 group-hover:text-amber-400 transition-colors text-sm font-medium">
            View on Amazon &rarr;
          </span>
        </a>
        <a
          href="https://www.amazon.com/dp/B0FXRGCY7C"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 flex flex-col hover:border-neutral-600 transition-colors group"
        >
          <p class="text-sm text-neutral-500 uppercase tracking-wider font-semibold mb-3">2" duty belt</p>
          <p class="text-white font-medium mb-1 group-hover:text-amber-500 transition-colors">Heavy Duty 2 inch duty belt</p>
          <p class="text-neutral-500 text-sm mb-4 flex-1">
            A plain 2" duty belt — no MOLLE webbing, a bit cheaper. Works with every 52mm Kanix™ plate or belt-clip variant.
          </p>
          <span class="inline-flex items-center gap-2 text-amber-500 group-hover:text-amber-400 transition-colors text-sm font-medium">
            View on Amazon &rarr;
          </span>
        </a>
        <a
          href="https://www.amazon.com/dp/B0FJDMN78R"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 flex flex-col hover:border-neutral-600 transition-colors group"
        >
          <p class="text-sm text-neutral-500 uppercase tracking-wider font-semibold mb-3">1.5" duty belt</p>
          <p class="text-white font-medium mb-1 group-hover:text-amber-500 transition-colors">IDOGEAR SPORTS Tactical Ratchet Belt</p>
          <p class="text-neutral-500 text-sm mb-4 flex-1">
            A 1.5" tactical ratchet belt — smaller footprint, same Kanix™ bolt pattern. Use with any 38mm Kanix™ plate or belt-clip variant.
          </p>
          <span class="inline-flex items-center gap-2 text-amber-500 group-hover:text-amber-400 transition-colors text-sm font-medium">
            View on Amazon &rarr;
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Custom Requests -->
  <section id="custom-requests" class="py-24 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-8">
        Need Something That's Not Here Yet?
      </h2>
      <div class="text-neutral-400 leading-relaxed">
        <p class="mb-4 text-lg text-neutral-300">
          Did we forget something? Have a new idea?
        </p>
        <p class="mb-4">
          Whether it's a <strong class="text-white">module for a piece of gear we don't cover yet</strong>
          or <strong class="text-white">support for a different belt size</strong> — open an issue on our
          GitHub page and describe what you need.
        </p>
        <ul class="mb-4 space-y-2 list-disc pl-6 text-left max-w-xl mx-auto">
          <li>
            <strong class="text-white">New module:</strong> tell us what you want to mount, its rough
            dimensions, and how you'd like it to attach.
          </li>
          <li>
            <strong class="text-white">New belt size:</strong> tell us the belt width (and thickness, if
            unusual) plus a link to a representative product so we can size the plate correctly.
          </li>
          <li>
            <strong class="text-white">Anything else:</strong> ideas, suggestions, improvements to an
            existing module, or just a question — we want to hear it. No idea is too small.
          </li>
        </ul>
        <p class="mb-8">
          An issue is just a message on our project page. You don't need to know how to code — just
          create a free GitHub account, click "New Issue," and tell us what you're looking for.
          We'll work with you to design it.
        </p>
      </div>
      <a
        href={`${repoUrl}/issues/new`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-3 bg-white text-neutral-950 font-semibold rounded-lg hover:bg-neutral-200 transition-colors"
      >
        Open an Issue &rarr;
      </a>
    </div>
  </section>

  <!-- License -->
  <section id="license" class="py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-8 text-center">
        License
      </h2>
