---
import Base from "../layouts/Base.astro";
import { modules } from "../data/modules";

const repoUrl = "https://github.com/mmmaxwwwell/kanix";
---

<Base
  title="Kanix™ - Open-Source Modular Dog Handler Belt System"
  description="Kanix™ is a free, open-source modular belt system for dog handlers. Built for trainers, walkers, and everyday dog owners."
>
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 bg-neutral-950/80 backdrop-blur-md border-b border-neutral-800">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <span class="text-xl font-extrabold tracking-tight">KANIX<sup class="text-[0.5em] align-super">™</sup></span>
      <div class="hidden sm:flex items-center gap-6">
        <a href="#modules" class="text-sm text-neutral-400 hover:text-white transition-colors">Modules</a>
        <a href="#the-belt" class="text-sm text-neutral-400 hover:text-white transition-colors">The Belt</a>
        <a href="#how-it-works" class="text-sm text-neutral-400 hover:text-white transition-colors">How It Works</a>
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-neutral-400 hover:text-white transition-colors"
        >
          GitHub
        </a>
      </div>
      <button
        id="nav-toggle"
        class="sm:hidden text-neutral-400 hover:text-white transition-colors"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
    <div id="mobile-nav" class="hidden sm:hidden border-t border-neutral-800 px-6 py-4 flex flex-col gap-4">
      <a href="#modules" class="text-sm text-neutral-400 hover:text-white transition-colors">Modules</a>
      <a href="#the-belt" class="text-sm text-neutral-400 hover:text-white transition-colors">The Belt</a>
      <a href="#how-it-works" class="text-sm text-neutral-400 hover:text-white transition-colors">How It Works</a>
      <a
        href={repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-neutral-400 hover:text-white transition-colors"
      >
        GitHub
      </a>
    </div>
  </nav>

  <main id="main">
  <!-- Hero -->
  <section id="hero" class="relative min-h-screen flex items-center justify-center px-6 pt-20 transition-[min-height] duration-100 ease-out">
    <div class="max-w-3xl text-center">
      <h1 class="text-5xl sm:text-7xl font-black tracking-tight leading-[1.05] mb-6">
        Your Belt.<br />Your Build.<br />Your Way.
      </h1>
      <p class="text-sm font-semibold tracking-widest uppercase text-amber-500 mb-6">
        Free & Open Source
      </p>
      <p class="text-lg sm:text-xl text-neutral-400 max-w-xl mx-auto mb-10 leading-relaxed">
        Kanix™ is a modular belt system for dog handlers. Mix and match modules to build
        the perfect setup for training, walking, or working with dogs.
      </p>
      <a
        href="#modules"
        class="inline-flex items-center gap-2 px-8 py-3 bg-white text-neutral-950 font-semibold rounded-lg hover:bg-neutral-200 transition-colors"
      >
        Explore Modules
      </a>
    </div>
  </section>

  <script>
    const hero = document.getElementById("hero")!;
    const content = hero.firstElementChild as HTMLElement;

    function onScroll() {
      const scrollY = window.scrollY;
      const contentHeight = content.offsetHeight + 80; // content + padding
      const viewportHeight = window.innerHeight;
      const extraSpace = viewportHeight - contentHeight;

      if (extraSpace <= 0) return; // content already fills viewport

      const collapse = Math.min(scrollY * 3, extraSpace);
      hero.style.minHeight = `${viewportHeight - collapse}px`;
    }

    window.addEventListener("scroll", onScroll, { passive: true });

    // Mobile nav toggle
    const navToggle = document.getElementById("nav-toggle")!;
    const mobileNav = document.getElementById("mobile-nav")!;

    navToggle.addEventListener("click", () => {
      const open = mobileNav.classList.toggle("hidden");
      navToggle.setAttribute("aria-expanded", String(!open));
    });

    mobileNav.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        mobileNav.classList.add("hidden");
        navToggle.setAttribute("aria-expanded", "false");
      });
    });
  </script>

  <!-- Who it's for -->
  <section class="py-24 px-6">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-12">
        Built for Every Dog Handler
      </h2>
      <div class="grid sm:grid-cols-3 gap-8">
        {[
          {
            title: "Professional Trainers",
            text: "Keep spray, treats, leads, and tools organized and instantly accessible during sessions with reactive or high-energy dogs.",
          },
          {
            title: "Dog Walkers",
            text: "Manage multiple dogs with hands-free gear. Poo bags, flashlights, and leash anchors all in easy reach while keeping both hands on the leads.",
          },
          {
            title: "Everyday Owners",
            text: "Simplify your daily walks. Stop juggling bags, treats, and flashlights in your pockets. Build a belt setup that fits your routine.",
          },
        ].map(({ title, text }) => (
          <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-8 text-left">
            <h3 class="text-lg font-semibold mb-3 text-white">{title}</h3>
            <p class="text-neutral-400 leading-relaxed">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What is Kanix -->
  <section class="py-24 px-6 bg-neutral-900/50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-8 text-center">
        What is Kanix™?
      </h2>
      <div class="text-neutral-400 leading-relaxed max-w-3xl mx-auto">
        <p class="mb-4">
          Kanix™ is a modular mounting system that turns any duty belt into a fully customized dog
          handling rig. Each module snaps onto a standard Kanix™ belt clip using a
          universal bolt pattern, so you can rearrange your gear in seconds.
        </p>
        <p class="mb-4">
          Whether you're a professional trainer managing reactive dogs, a dog walker juggling
          multiple leashes, or an owner who just wants hands-free access to bags and treats,
          Kanix™ gives you a system that adapts to your workflow.
        </p>
        <p>
          Every module is designed in OpenSCAD, fully parametric, and released under an open-source
          license. Download the files and print them yourself, modify the designs to fit your exact
          gear, or contribute your own modules back to the community.
        </p>
      </div>
    </div>
  </section>

  <!-- Why Kanix -->
  <section class="py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-8 text-center">
        Why Kanix™?
      </h2>
      <div class="text-neutral-400 leading-relaxed max-w-3xl mx-auto">
        <p class="mb-4">
          Kanix™ started because of a problem every dog owner knows: you're on a walk with pockets
          stuffed full of bags, treats, a flashlight, your phone, and keys, and none of it is where
          you need it when you need it. The treat pouch belt is sliding down your waist again.
          The clip-on bag holder fell off somewhere two blocks back. And your dog just
          pooped in the neighbor's yard, but the bags are sitting on the kitchen counter.
        </p>
        <p class="mb-4">
          And if an off-leash dog ever charges yours, you need your spray immediately, not
          buried in a pocket. You don't get to fumble when seconds count. Your gear needs to be
          in a fixed position, right where your hand expects it, every single time.
        </p>
        <p>
          That's why Kanix™ exists, a sturdy duty belt that doesn't sag or shift, with purpose-built
          mounts that keep every piece of gear locked in place and instantly accessible. No more
          juggling. No more hoping you can find what you need in time.
        </p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section id="how-it-works" class="py-24 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-12">
        How It Works
      </h2>
      <div class="grid sm:grid-cols-3 gap-8">
        {[
          {
            step: "1",
            title: "Choose Your Modules",
            text: "Browse the available modules and pick the ones that match your gear and workflow.",
          },
          {
            step: "2",
            title: "Print",
            text: "Download the OpenSCAD files and 3D print them yourself. Modify the parametric designs to fit your exact gear.",
          },
          {
            step: "3",
            title: "Mount & Go",
            text: "Bolt your modules onto Kanix™ belt clips, slide them onto your duty belt, and rearrange anytime.",
          },
        ].map(({ step, title, text }) => (
          <div class="text-left">
            <div class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-amber-500/10 text-amber-500 font-bold text-lg mb-4">
              {step}
            </div>
            <h3 class="text-lg font-semibold mb-2 text-white">{title}</h3>
            <p class="text-neutral-400 leading-relaxed">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- The Belt -->
  <section id="the-belt" class="py-24 px-6 bg-neutral-900/50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-8 text-center">
        What's a Duty Belt?
      </h2>
      <div class="text-neutral-400 leading-relaxed max-w-3xl mx-auto">
        <p class="mb-4">
          A duty belt is a rigid, heavy-duty belt originally designed for law enforcement and military
          use. Unlike a regular belt, it's built to carry weight without sagging, distributing
          the load of holsters, pouches, and tools evenly around your waist.
        </p>
        <p class="mb-4">
          Kanix™ is designed around a standard 2" (51mm) duty belt. The wide, stiff construction
          gives you a stable platform to mount modules that won't shift or bounce while you're
          handling dogs.
        </p>
        <p class="mb-8">
          Any 2" duty belt will work. We're currently prototyping with the belt linked below,
          but the system is designed to be belt-agnostic. If it's 2" wide and rigid, it's compatible.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6">
          <p class="text-sm text-neutral-500 uppercase tracking-wider font-semibold mb-3">Recommended Belt</p>
          <p class="text-white font-medium mb-1">2" Tactical Duty Belt</p>
          <p class="text-neutral-500 text-sm mb-4">Rigid, double-layered nylon. The belt we use for prototyping all Kanix™ modules.</p>
          <a
            href="https://www.amazon.com/dp/B0FXRGCY7C"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-amber-500 hover:text-amber-400 transition-colors text-sm font-medium"
          >
            View on Amazon &rarr;
          </a>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6">
          <p class="text-sm text-neutral-500 uppercase tracking-wider font-semibold mb-3">Mounting Hardware</p>
          <p class="text-white font-medium mb-1">M5x10 Button Head Cap Screws</p>
          <p class="text-neutral-500 text-sm mb-4">Used to mount most modules to belt clips. Stainless steel, fits the standard Kanix™ bolt pattern.</p>
          <a
            href="https://www.amazon.com/dp/B08DS7XJN8"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-amber-500 hover:text-amber-400 transition-colors text-sm font-medium"
          >
            View on Amazon &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Modules -->
  <section id="modules" class="py-24 px-6 bg-neutral-900/50">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4 text-center">
        Available Modules
      </h2>
      <p class="text-neutral-400 text-center mb-12 max-w-xl mx-auto">
        Each module mounts to a standard 3x3 Kanix™ bolt pattern with M5 hardware. Mix, match, and rearrange to suit your needs.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {modules.map(({ slug, name, description }) => (
          <a
            href={`${import.meta.env.BASE_URL}modules/${slug}/`}
            class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 flex flex-col hover:border-neutral-600 transition-colors group"
          >
            <h3 class="text-lg font-semibold mb-2 text-white group-hover:text-amber-500 transition-colors">{name}</h3>
            <p class="text-neutral-400 leading-relaxed mb-4 flex-1">{description}</p>
            <span class="text-sm text-amber-500 group-hover:text-amber-400 transition-colors font-medium">
              View 3D Model &rarr;
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Custom Modules -->
  <section class="py-24 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-8">
        Need a Custom Module?
      </h2>
      <div class="text-neutral-400 leading-relaxed">
        <p class="mb-4">
          Don't see a module for your gear? Open an issue on our GitHub page and describe what
          you need: the item you want to mount, its dimensions, and how you'd like it to attach.
        </p>
        <p class="mb-8">
          An issue is just a message on our project page. You don't need to know how to code, just
          create a free GitHub account, click "New Issue," and tell us what you're looking for.
          We'll work with you to design it.
        </p>
      </div>
      <a
        href={`${repoUrl}/issues/new`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-3 bg-white text-neutral-950 font-semibold rounded-lg hover:bg-neutral-200 transition-colors"
      >
        Open an Issue &rarr;
      </a>
    </div>
  </section>

  <!-- License -->
  <section id="license" class="py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-8 text-center">
        License
      </h2>
      <div class="grid sm:grid-cols-2 gap-8">
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-8">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-green-500/10 text-green-500 font-bold text-lg mb-4">
            ✓
          </div>
          <h3 class="text-lg font-semibold mb-3 text-white">Personal Use</h3>
          <p class="text-neutral-400 leading-relaxed mb-4">
            Kanix™ is licensed under <a href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="noopener noreferrer" class="text-amber-500 hover:text-amber-400 transition-colors">CC BY-NC 4.0</a>.
            You are free to download, print, modify, and share these designs for personal,
            non-commercial use. Print them for yourself, your friends, your dog walker, no
            permission needed. Just give credit to the project.
          </p>
          <ul class="text-neutral-400 text-sm space-y-2">
            <li>✓ Print for yourself</li>
            <li>✓ Modify the designs</li>
            <li>✓ Share with others</li>
            <li>✓ Print as gifts</li>
          </ul>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-8">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-amber-500/10 text-amber-500 font-bold text-lg mb-4">
            $
          </div>
          <h3 class="text-lg font-semibold mb-3 text-white">Commercial Use</h3>
          <p class="text-neutral-400 leading-relaxed mb-4">
            Want to sell printed Kanix™ modules, include them in a product, or use the designs
            in a commercial service? You'll need a commercial license. This keeps the project
            sustainable and ensures quality for end users.
          </p>
          <ul class="text-neutral-400 text-sm space-y-2 mb-6">
            <li>✗ No selling printed modules without a license</li>
            <li>✗ No commercial services using the designs</li>
            <li>✗ No including in paid products or kits</li>
          </ul>
          <a
            href={`${repoUrl}#commercial-licensing`}
            class="inline-flex items-center gap-2 text-amber-500 hover:text-amber-400 transition-colors text-sm font-medium"
          >
            Contact for commercial licensing &rarr;
          </a>
        </div>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 mt-8 max-w-3xl mx-auto">
        <h3 class="text-sm font-semibold text-neutral-400 uppercase tracking-wider mb-3">Disclaimer</h3>
        <p class="text-neutral-500 text-xs leading-relaxed">
          These designs are provided "as is" without warranty of any kind. The creator assumes no
          liability for injury, damage, or loss resulting from the use of these designs or any
          parts printed from them. You are solely responsible for ensuring that printed parts are
          suitable and safe for your intended use, including material selection, print quality, and
          structural integrity. 3D-printed parts can fail without warning, so inspect your gear
          regularly and replace any parts showing signs of wear or damage. Use at your own risk.
        </p>
      </div>
    </div>
  </section>

  </main>

  <!-- Footer -->
  <footer class="py-12 px-6 border-t border-neutral-800">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="text-sm text-neutral-500">
        Licensed under <a href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="noopener noreferrer" class="underline hover:text-white transition-colors">CC BY-NC 4.0</a>. Free for personal use. <a href={`${repoUrl}#commercial-licensing`} class="underline hover:text-white transition-colors">Commercial licensing available</a>.
      </span>
      <a
        href={repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-neutral-500 hover:text-white transition-colors"
      >
        GitHub
      </a>
    </div>
    <p class="text-neutral-500 text-xs text-center mt-6">
      &copy; 2026 mmmaxwwwell. All rights reserved. Kanix™ designs are original works by mmmaxwwwell.
    </p>
  </footer>
</Base>
