---
import Base from "../layouts/Base.astro";
---

<Base
  title="Order Confirmed - Kanix™ Shop"
  description="Your Kanix™ order has been confirmed"
>
  <nav class="fixed top-0 w-full z-50 bg-neutral-950/80 backdrop-blur-md border-b border-neutral-800">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href={import.meta.env.BASE_URL} class="text-xl font-extrabold tracking-tight hover:text-neutral-300 transition-colors">KANIX<sup class="text-[0.5em] align-super">™</sup></a>
      <div class="hidden sm:flex items-center gap-6">
        <a href={import.meta.env.BASE_URL} class="text-sm text-neutral-400 hover:text-white transition-colors">Home</a>
        <a href={`${import.meta.env.BASE_URL}products/`} class="text-sm text-neutral-400 hover:text-white transition-colors">Shop</a>
      </div>
    </div>
  </nav>

  <main id="main" class="pt-20 pb-16 px-4 sm:px-6">
    <div class="max-w-2xl mx-auto text-center">
      <!-- Success Icon -->
      <div class="w-16 h-16 bg-green-500/10 border border-green-500/20 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight mb-3">Order Confirmed</h1>
      <p class="text-neutral-400 mb-8">Thank you for your purchase!</p>

      <!-- Order Details -->
      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-left mb-8">
        <div class="space-y-3">
          <div class="flex justify-between">
            <span class="text-sm text-neutral-400">Order Number</span>
            <span id="order-number" class="text-sm font-semibold text-white">--</span>
          </div>
          <div class="flex justify-between">
            <span class="text-sm text-neutral-400">Confirmation Email</span>
            <span id="order-email" class="text-sm text-white">--</span>
          </div>
          <div id="order-total-row" class="flex justify-between hidden">
            <span class="text-sm text-neutral-400">Total</span>
            <span id="order-total" class="text-sm font-semibold text-white">--</span>
          </div>
        </div>
      </div>

      <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-left mb-8">
        <h2 class="text-sm font-semibold text-neutral-400 uppercase tracking-wider mb-3">What Happens Next</h2>
        <ul class="space-y-2 text-sm text-neutral-400">
          <li class="flex items-start gap-2">
            <span class="text-amber-500 mt-0.5">1.</span>
            <span>You'll receive an order confirmation email shortly.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber-500 mt-0.5">2.</span>
            <span>Your order will be prepared and shipped within 1-3 business days.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber-500 mt-0.5">3.</span>
            <span>You'll receive a shipping confirmation with tracking information.</span>
          </li>
        </ul>
      </div>

      <a
        href={`${import.meta.env.BASE_URL}products/`}
        class="inline-flex items-center gap-2 px-6 py-3 bg-amber-500 text-neutral-950 font-semibold rounded-lg hover:bg-amber-400 transition-colors text-sm"
      >
        Continue Shopping
      </a>
    </div>
  </main>

  <footer class="py-12 px-6 border-t border-neutral-800">
    <div class="max-w-6xl mx-auto text-center text-sm text-neutral-500 space-y-2">
      <p>&copy; 2026 mmmaxwwwell. All rights reserved. Kanix™ designs are original works by mmmaxwwwell.</p>
    </div>
  </footer>
</Base>

<script>
  import { formatPrice, clearCartToken } from "../lib/cart";

  // Parse order details from URL params
  const params = new URLSearchParams(window.location.search);
  const orderNumber = params.get("order_number");
  const email = params.get("email");
  const totalMinor = params.get("total");

  if (orderNumber) {
    document.getElementById("order-number")!.textContent = orderNumber;
  }
  if (email) {
    document.getElementById("order-email")!.textContent = email;
  }
  if (totalMinor) {
    const totalRow = document.getElementById("order-total-row")!;
    totalRow.classList.remove("hidden");
    document.getElementById("order-total")!.textContent = formatPrice(parseInt(totalMinor, 10));
  }

  // Ensure cart token is cleared after successful order
  clearCartToken();
</script>
