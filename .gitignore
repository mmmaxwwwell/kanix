reasoning/
claims/

# code-review-graph state — SQLite knowledge graph db, watcher logs, pid files
.code-review-graph/

# Agent-side ad-hoc renders (kanix-plate refactor iteration previews)
renders/

# Agent / spec-kit / dev scratch — local artifacts that should never have
# been tracked. Anything matching these patterns is per-machine state.
.playwright-mcp/
mem-repro-*.jsonl
cost-report.json
cost-report.md
specs/admin/run-log.jsonl
specs/admin/run-log.jsonl.*

# API + root local data dirs (evidence-bundle JSON, ticket attachments,
# signed receipts) generated by integration test runs.
api/data/attachments/
data/attachments/

# E2E setup scratch
test/e2e/.state/env
test/e2e/.state/setup-failure.log

# stl-pipeline Python cache
stl-pipeline/**/__pycache__/
