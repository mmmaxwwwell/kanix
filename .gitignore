.claude/
*.stl

# Model artifacts — neither plaintext nor encrypted blobs are tracked.
# Decryption produces ./models/; encryption produces ./models.enc/.
# Operators sync these out-of-band; only the scripts in scripts/ live in git.
models/
models.enc/

# Per-operator Yubikey identity stubs (recipient pointers used by
# scripts/decrypt-models.sh). Each contributor generates their own with
# `age-plugin-yubikey -i`.
.age-yubikey-identity-*.txt

# Spec-kit / agent artifacts
test-logs/
logs/
validate/
attempts/
ci-debug/
BLOCKED.md

# Environment
.env
.env.local
.env.*.local
site/.env

# Direnv
.direnv/

# Editor / OS
.DS_Store
*.swp
*~

# Nix
result

# Security
*.pem
*.key
credentials.json

