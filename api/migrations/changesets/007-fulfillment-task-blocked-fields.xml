<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="007-fulfillment-task-blocked-fields" author="kanix">
        <comment>
            Add blocked_reason and pre_blocked_status columns to fulfillment_task
            to track why a task was blocked and which state to return to on unblock.
        </comment>

        <addColumn tableName="fulfillment_task">
            <column name="blocked_reason" type="text">
                <constraints nullable="true" />
            </column>
            <column name="pre_blocked_status" type="text">
                <constraints nullable="true" />
            </column>
        </addColumn>

        <rollback>
            <dropColumn tableName="fulfillment_task" columnName="blocked_reason" />
            <dropColumn tableName="fulfillment_task" columnName="pre_blocked_status" />
        </rollback>
    </changeSet>

</databaseChangeLog>
