<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="009-contributor-donation-fields" author="kanix">
        <comment>
            Add charity_name and charity_ein columns to contributor table for
            501(c)(3) donation option. When both are set, royalties are calculated
            at 2x rate (20% instead of 10%).
        </comment>

        <addColumn tableName="contributor">
            <column name="charity_name" type="text" />
            <column name="charity_ein" type="text" />
        </addColumn>

        <rollback>
            <dropColumn tableName="contributor" columnName="charity_name" />
            <dropColumn tableName="contributor" columnName="charity_ein" />
        </rollback>
    </changeSet>

</databaseChangeLog>
