{
  "name": "@kanix/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ && prettier --check src/",
    "lint:fix": "eslint src/ --fix && prettier --write src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "db:migrate": "liquibase update",
    "db:rollback": "liquibase rollback-count 1",
    "db:seed": "tsx src/db/scripts/seed.ts",
    "db:reset": "tsx src/db/scripts/reset.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "stripe": "^22.0.2",
    "supertokens-node": "^24.0.2",
    "ws": "^8.20.0"
  }
}
